{
  "name": "@thesis/app",
  "version": "0.1.0",
  "private": true,
  "description": "Desktop and web app for the visual data structures editor thesis project.",
  "author": "Argedia",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "build": "tsc -p tsconfig.json --noEmit && vite build",
    "build:desktop-renderer": "tsc -p tsconfig.json --noEmit && vite build",
    "build:desktop": "npm run build:desktop-renderer && npm run package:desktop",
    "desktop:debug": "npm run build:desktop-renderer && cross-env ELECTRON_DEBUG=1 electron .",
    "desktop:dev": "concurrently -k \"vite --host 127.0.0.1 --port 5173\" \"wait-on tcp:127.0.0.1:5173 && cross-env VITE_DEV_SERVER_URL=http://127.0.0.1:5173 electron .\"",
    "dev": "vite",
    "generate:icon": "powershell -ExecutionPolicy Bypass -File ../scripts/generate-electron-icon.ps1",
    "package:desktop": "electron-packager . \"Visual Data Structures Editor\" --platform=win32 --arch=x64 --out=release --overwrite --asar --prune=false --icon=build/icon.ico --ignore=\"^/(src|public|release|node_modules/.cache)\""
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.108.0",
    "@thesis/core-engine": "0.1.0",
    "@thesis/game-system": "0.1.0",
    "@thesis/storage": "0.1.0",
    "@thesis/ui-editor": "0.1.0",
    "driver.js": "^1.4.0",
    "i18next": "^26.0.4",
    "immer": "^11.1.4",
    "lucide-react": "^1.21.0",
    "react": "^18.3.1",
    "react-aria-components": "^1.16.0",
    "react-dom": "^18.3.1",
    "react-i18next": "^17.0.2",
    "react-router-dom": "^6.28.0",
    "zustand": "^5.0.1"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "9.2.3",
    "cross-env": "7.0.3",
    "electron": "31.7.7",
    "electron-builder": "24.13.3",
    "electron-packager": "^17.1.2",
    "typescript": "^5.6.3",
    "vite": "^5.4.10",
    "wait-on": "8.0.5"
  },
  "build": {
    "appId": "com.argedia.thesis",
    "productName": "Visual Data Structures Editor",
    "directories": {
      "output": "release"
    },
    "artifactName": "${productName}-Setup-${version}.${ext}",
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "win": {
      "icon": "build/icon.ico",
      "signAndEditExecutable": false,
      "target": [
        "nsis"
      ]
    },
    "nsis": {
      "installerIcon": "build/icon.ico",
      "uninstallerIcon": "build/icon.ico",
      "installerHeaderIcon": "build/icon.ico",
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
