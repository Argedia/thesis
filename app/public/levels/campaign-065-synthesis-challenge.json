    "messages": [
      {
        "trigger": "level_start",
        "title": "Put everything together",
        "body": "Stack S has 8 values. Your job is to route each one: even values go to queue Q, odd values go to list L. The stack is large on purpose — write a helper function so the main routine stays clean and simple.",
        "concepts": ["routing", "helper function", "multi-structure"]
      },
      {
        "trigger": "first_failure",
        "title": "Check the condition inside the helper",
        "body": "The function runs once per value. It should pop from S, check the value, then enqueue or append based on what it found. If the split is wrong, look at how the parity check is structured.",
        "concepts": ["parity check", "conditional dispatch", "POP then route"]
      },
      {
        "trigger": "repeated_failure",
        "title": "Keep main simple, let the helper do the work",
        "body": "The main routine just loops until S is empty. All the decision logic — the if/else, the enqueue vs append — lives inside the helper. If main is growing, move that logic back into the function.",
        "concepts": ["separation of concerns", "loop in main", "logic in helper"]
      }
    ]
