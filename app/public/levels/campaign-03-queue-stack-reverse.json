  "teaching": {
    "introduces": ["queue front behavior", "using a stack as auxiliary memory", "contrasting FIFO and LIFO"],
    "messages": [
      {
        "trigger": "level_start",
        "title": "This level introduces queue order",
        "body": "Queues and stacks do not release values the same way. A queue removes from the front, while a stack removes from the top. This level teaches how a stack can temporarily change the order of values coming from a queue.",
        "concepts": ["queue front", "stack top", "FIFO vs LIFO"]
      },
      {
        "trigger": "first_failure",
        "title": "Watch where values leave from",
        "body": "If the order is wrong, the mistake is usually assuming the queue behaves like a stack. Dequeue removes the oldest visible value, not the newest one.",
        "concepts": ["DEQUEUE", "oldest first"]
      },
      {
        "trigger": "repeated_failure",
        "title": "The helper structure changes order",
        "body": "The stack is not the final goal here; it is the mechanism that flips order while values pass through it. Think about what order values have after entering and leaving the helper stack.",
        "concepts": ["auxiliary structure", "order reversal"]
      }
    ]
  }
