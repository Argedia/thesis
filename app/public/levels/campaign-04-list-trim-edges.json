      {
        "trigger": "first_failure",
        "title": "Preserve the middle",
        "body": "The center of the list should survive unchanged. If the middle values moved or disappeared, the operation sequence trimmed more than the two outer positions.",
        "concepts": ["middle values", "edge-only changes"]
      },
      {
        "trigger": "repeated_failure",
        "title": "Each edge is a different position",
        "body": "This level is not about general stack or queue movement. It is about targeting the current first item and the current last item of the same structure.",
