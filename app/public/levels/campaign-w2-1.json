          "pila auxiliar",
          "tope",
          "restauración"
        ]
      },
      {
        "trigger": "first_failure",
        "title": "Restaurar también forma parte de la solución",
        "body": "Si B recibió el valor correcto pero A quedó mal, faltó devolver a A el elemento que solo salió para despejar el camino.",
        "concepts": [
          "estado final exacto",
          "restaurar"
        ]
      },
      {
        "trigger": "repeated_failure",
        "title": "Piensa en tres movimientos",
        "body": "Primero aparta, luego rescata, y al final devuelve. Esa secuencia respeta la lógica LIFO sin perder información.",
        "concepts": [
          "secuencia de estrategia",
          "LIFO"
        ]
      }
    ]
