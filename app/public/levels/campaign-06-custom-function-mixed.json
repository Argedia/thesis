    "messages": [
      {
        "trigger": "level_start",
        "title": "This level mixes functions with structure differences",
        "body": "Now the reusable helper must respect that the source is a stack and the target is a queue. The lesson is that abstraction still works, but the function must preserve the meaning of each structure operation.",
        "concepts": [
          "function reuse",
          "stack source",
          "queue target"
        ]
      },
      {
        "trigger": "first_failure",
        "title": "Reuse does not erase structure rules",
        "body": "A function can simplify the program, but it does not change what POP and ENQUEUE mean. If the final order is wrong, check whether the helper respects the destination queue behavior.",
        "concepts": [
          "ENQUEUE",
          "destination behavior"
        ]
      },
      {
        "trigger": "repeated_failure",
        "title": "Abstract the move, not the result",
        "body": "The helper should describe the action that happens each time. The final pattern emerges from repeated calls plus the structure semantics, especially the queue receiving order.",
        "concepts": [
          "action abstraction",
          "receiving order"
        ]
      }
    ]
