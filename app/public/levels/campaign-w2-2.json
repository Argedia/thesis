          "PEEK",
          "chequeo previo"
        ]
      },
      {
        "trigger": "repeated_failure",
        "title": "El traslado debe estar justificado",
        "body": "La meta no es mover por mover. La idea de este nivel es que la acción suceda como resultado de una verificación simple sobre el valor visible.",
        "concepts": [
          "condición útil",
          "acción verificada"
        ]
      }
    ]
