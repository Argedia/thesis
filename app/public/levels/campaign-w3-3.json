  "teachingPlan": {
    "introduces": [
      "Repetición con while usando el tamaño de una cola como condición"
    ],
    "reinforces": [
      "SIZE",
      "comparación con 0",
      "una acción por iteración"
    ],
    "messages": [
      {
        "trigger": "level_start",
        "title": "El while evita duplicar bloques",
        "body": "Hay varios elementos y todos requieren la misma acción. En vez de copiar el patrón muchas veces, usa un while que repita mientras A tenga tamaño mayor que 0.",
        "concepts": [
          "while",
          "SIZE",
          "repetición"
        ]
      },
      {
        "trigger": "first_failure",
        "title": "La condición controla cuándo termina",
        "body": "Si el programa se queda corto o se pasa, revisa la condición del while. El cuerpo puede ser correcto y aun así fallar si la repetición termina mal.",
        "concepts": [
          "condición de salida",
          "while"
        ]
      },
      {
        "trigger": "repeated_failure",
        "title": "Una transferencia por vuelta",
        "body": "Cada iteración debería hacer exactamente el mismo movimiento: sacar del frente de A y enviar al final de B. El while se encarga de repetir.",
        "concepts": [
          "cuerpo del while",
          "FIFO"
        ]
      }
    ]
  },
